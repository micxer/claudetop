#!/usr/bin/env python3
"""
claudetop-engine — Analytics engine for claudetop.

Scans Claude Code JSONL session transcripts, stores per-turn data in SQLite,
and serves an interactive web dashboard. Zero external dependencies.

Commands:
  scan        Scan JSONL files and update ~/.claude/claudetop.db
  today       Show today's usage summary
  stats       Show all-time statistics
  dashboard   Scan + start live dashboard at http://localhost:8080

https://github.com/liorwn/claudetop
"""

import json
import os
import glob
import sqlite3
import sys
import threading
import time
import webbrowser
from pathlib import Path
from datetime import datetime, timezone, timedelta, date
from http.server import HTTPServer, BaseHTTPRequestHandler
from collections import defaultdict
from urllib.parse import urlparse, parse_qs

# ── Constants ────────────────────────────────────────────────────────────────

PROJECTS_DIR = Path.home() / ".claude" / "projects"
DB_PATH = Path.home() / ".claude" / "claudetop.db"
HISTORY_FILE = Path.home() / ".claude" / "claudetop-history.jsonl"
PRICING_FILE = Path.home() / ".claude" / "claudetop-pricing.json"

# Fallback pricing (Claude 4.6, April 2026)
DEFAULT_PRICING = {
    "opus":   {"input": 5.00, "cache_write": 6.25, "cache_read": 0.50, "output": 25.00},
    "sonnet": {"input": 3.00, "cache_write": 3.75, "cache_read": 0.30, "output": 15.00},
    "haiku":  {"input": 1.00, "cache_write": 1.25, "cache_read": 0.10, "output":  5.00},
}


def load_pricing():
    """Load pricing from claudetop-pricing.json or use defaults."""
    if PRICING_FILE.exists():
        try:
            data = json.loads(PRICING_FILE.read_text())
            models = data.get("models", {})
            result = {}
            for family in ("opus", "sonnet", "haiku"):
                m = models.get(family, {})
                result[family] = {
                    "input": m.get("input", DEFAULT_PRICING[family]["input"]),
                    "cache_write": m.get("cache_write_5min", m.get("cache_write", DEFAULT_PRICING[family]["cache_write"])),
                    "cache_read": m.get("cache_read", DEFAULT_PRICING[family]["cache_read"]),
                    "output": m.get("output", DEFAULT_PRICING[family]["output"]),
                }
            return result
        except Exception:
            pass
    return DEFAULT_PRICING


PRICING = load_pricing()


def model_family(model_id):
    if not model_id:
        return None
    model_id = model_id.lower()
    if "opus" in model_id:
        return "opus"
    if "sonnet" in model_id:
        return "sonnet"
    if "haiku" in model_id:
        return "haiku"
    return None


def calc_cost(model, inp, out, cache_read, cache_creation):
    family = model_family(model)
    if not family:
        family = "sonnet"  # default to sonnet pricing
    p = PRICING[family]
    return (
        inp * p["input"] / 1_000_000
        + out * p["output"] / 1_000_000
        + cache_read * p["cache_read"] / 1_000_000
        + cache_creation * p["cache_write"] / 1_000_000
    )


def fmt_tokens(n):
    if n >= 1_000_000:
        return f"{n / 1_000_000:.1f}M"
    if n >= 1_000:
        return f"{n / 1_000:.1f}K"
    return str(n)


def fmt_cost(c):
    if c >= 1:
        return f"${c:.2f}"
    return f"${c:.3f}"


# ── Database ─────────────────────────────────────────────────────────────────

def get_db():
    conn = sqlite3.connect(DB_PATH)
    conn.row_factory = sqlite3.Row
    return conn


def init_db(conn):
    conn.executescript("""
        CREATE TABLE IF NOT EXISTS sessions (
            session_id        TEXT PRIMARY KEY,
            project_name      TEXT,
            project_dir       TEXT,
            first_timestamp   TEXT,
            last_timestamp    TEXT,
            git_branch        TEXT,
            total_input       INTEGER DEFAULT 0,
            total_output      INTEGER DEFAULT 0,
            total_cache_read  INTEGER DEFAULT 0,
            total_cache_write INTEGER DEFAULT 0,
            model             TEXT,
            turn_count        INTEGER DEFAULT 0,
            is_subagent       INTEGER DEFAULT 0,
            parent_session_id TEXT
        );

        CREATE TABLE IF NOT EXISTS turns (
            id                INTEGER PRIMARY KEY AUTOINCREMENT,
            session_id        TEXT,
            timestamp         TEXT,
            model             TEXT,
            input_tokens      INTEGER DEFAULT 0,
            output_tokens     INTEGER DEFAULT 0,
            cache_read        INTEGER DEFAULT 0,
            cache_write       INTEGER DEFAULT 0,
            tool_name         TEXT,
            cwd               TEXT
        );

        CREATE TABLE IF NOT EXISTS processed_files (
            path   TEXT PRIMARY KEY,
            mtime  REAL,
            lines  INTEGER
        );

        CREATE INDEX IF NOT EXISTS idx_turns_session ON turns(session_id);
        CREATE INDEX IF NOT EXISTS idx_turns_ts ON turns(timestamp);
        CREATE INDEX IF NOT EXISTS idx_sessions_first ON sessions(first_timestamp);
        CREATE INDEX IF NOT EXISTS idx_sessions_subagent ON sessions(is_subagent);
    """)
    conn.commit()


# ── Scanner ──────────────────────────────────────────────────────────────────

def project_name_from_path(filepath, cwd=None):
    """Derive project name from file path or cwd."""
    if cwd:
        parts = cwd.replace("\\", "/").rstrip("/").split("/")
        if len(parts) >= 1:
            return parts[-1]
    # Fall back to JSONL file path structure
    # ~/.claude/projects/-Users-Lior-myproject/session.jsonl → myproject
    rel = str(filepath).replace(str(PROJECTS_DIR) + "/", "")
    folder = rel.split("/")[0]
    # Decode dashed path: -Users-Lior-myproject → myproject
    parts = folder.split("-")
    if len(parts) > 1:
        return parts[-1]
    return folder


def detect_subagent(filepath):
    """Check if a JSONL file is from a subagent. Returns (is_subagent, parent_session_id)."""
    path_str = str(filepath)
    if "/subagents/" in path_str:
        # Path pattern: .../SESSION_ID/subagents/agent-XXXXX.jsonl
        parts = path_str.split("/subagents/")
        if parts:
            parent_dir = parts[0].split("/")[-1]
            return True, parent_dir
    return False, None


def parse_jsonl_file(filepath):
    """Parse a JSONL file, yield session metadata and turns."""
    turns = []
    session_meta = {}
    is_sub, parent_id = detect_subagent(filepath)

    try:
        with open(filepath, encoding="utf-8", errors="replace") as f:
            for line in f:
                line = line.strip()
                if not line:
                    continue
                try:
                    record = json.loads(line)
                except json.JSONDecodeError:
                    continue

                rtype = record.get("type")
                if rtype not in ("assistant", "user"):
                    continue

                session_id = record.get("sessionId")
                if not session_id:
                    continue

                timestamp = record.get("timestamp", "")
                cwd = record.get("cwd", "")
                git_branch = record.get("gitBranch", "")

                if session_id not in session_meta:
                    session_meta[session_id] = {
                        "session_id": session_id,
                        "project_name": project_name_from_path(filepath, cwd),
                        "project_dir": cwd,
                        "first_timestamp": timestamp,
                        "last_timestamp": timestamp,
                        "git_branch": git_branch,
                        "model": None,
                        "is_subagent": 1 if is_sub else 0,
                        "parent_session_id": parent_id,
                    }
                else:
                    meta = session_meta[session_id]
                    if timestamp and (not meta["first_timestamp"] or timestamp < meta["first_timestamp"]):
                        meta["first_timestamp"] = timestamp
                    if timestamp and (not meta["last_timestamp"] or timestamp > meta["last_timestamp"]):
                        meta["last_timestamp"] = timestamp
                    if git_branch and not meta["git_branch"]:
                        meta["git_branch"] = git_branch
                    if cwd and (not meta["project_dir"] or len(cwd) > len(meta["project_dir"])):
                        meta["project_dir"] = cwd

                if rtype == "assistant":
                    msg = record.get("message", {})
                    usage = msg.get("usage", {})
                    model = msg.get("model", "")

                    input_tokens = usage.get("input_tokens", 0) or 0
                    output_tokens = usage.get("output_tokens", 0) or 0
                    cache_read = usage.get("cache_read_input_tokens", 0) or 0
                    cache_creation = usage.get("cache_creation_input_tokens", 0) or 0

                    if input_tokens + output_tokens + cache_read + cache_creation == 0:
                        continue

                    tool_name = None
                    for item in msg.get("content", []):
                        if isinstance(item, dict) and item.get("type") == "tool_use":
                            tool_name = item.get("name")
                            break

                    if model:
                        session_meta[session_id]["model"] = model

                    turns.append({
                        "session_id": session_id,
                        "timestamp": timestamp,
                        "model": model,
                        "input_tokens": input_tokens,
                        "output_tokens": output_tokens,
                        "cache_read": cache_read,
                        "cache_write": cache_creation,
                        "tool_name": tool_name,
                        "cwd": cwd,
                    })

    except Exception as e:
        print(f"  Warning: {filepath}: {e}")

    return list(session_meta.values()), turns


def aggregate_sessions(session_metas, turns):
    """Aggregate turns into session-level stats."""
    stats = defaultdict(lambda: {
        "total_input": 0, "total_output": 0,
        "total_cache_read": 0, "total_cache_write": 0,
        "turn_count": 0, "model": None,
    })
    for t in turns:
        s = stats[t["session_id"]]
        s["total_input"] += t["input_tokens"]
        s["total_output"] += t["output_tokens"]
        s["total_cache_read"] += t["cache_read"]
        s["total_cache_write"] += t["cache_write"]
        s["turn_count"] += 1
        if t["model"]:
            s["model"] = t["model"]

    result = []
    for meta in session_metas:
        sid = meta["session_id"]
        s = stats[sid]
        result.append({**meta, **s})
    return result


def upsert_sessions(conn, sessions):
    for s in sessions:
        existing = conn.execute(
            "SELECT session_id FROM sessions WHERE session_id = ?",
            (s["session_id"],)
        ).fetchone()

        if existing is None:
            conn.execute("""
                INSERT INTO sessions
                    (session_id, project_name, project_dir, first_timestamp, last_timestamp,
                     git_branch, total_input, total_output, total_cache_read, total_cache_write,
                     model, turn_count, is_subagent, parent_session_id)
                VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
            """, (
                s["session_id"], s["project_name"], s.get("project_dir", ""),
                s["first_timestamp"], s["last_timestamp"], s["git_branch"],
                s["total_input"], s["total_output"],
                s["total_cache_read"], s["total_cache_write"],
                s["model"], s["turn_count"],
                s.get("is_subagent", 0), s.get("parent_session_id"),
            ))
        else:
            conn.execute("""
                UPDATE sessions SET
                    last_timestamp = MAX(last_timestamp, ?),
                    total_input = total_input + ?,
                    total_output = total_output + ?,
                    total_cache_read = total_cache_read + ?,
                    total_cache_write = total_cache_write + ?,
                    turn_count = turn_count + ?,
                    model = COALESCE(?, model)
                WHERE session_id = ?
            """, (
                s["last_timestamp"],
                s["total_input"], s["total_output"],
                s["total_cache_read"], s["total_cache_write"],
                s["turn_count"], s["model"],
                s["session_id"],
            ))


def insert_turns(conn, turns):
    conn.executemany("""
        INSERT INTO turns
            (session_id, timestamp, model, input_tokens, output_tokens,
             cache_read, cache_write, tool_name, cwd)
        VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)
    """, [
        (t["session_id"], t["timestamp"], t["model"],
         t["input_tokens"], t["output_tokens"],
         t["cache_read"], t["cache_write"],
         t["tool_name"], t["cwd"])
        for t in turns
    ])


def count_lines(filepath):
    count = 0
    with open(filepath, encoding="utf-8", errors="replace") as f:
        for _ in f:
            count += 1
    return count


def scan(verbose=True):
    """Scan all JSONL files and update the database."""
    conn = get_db()
    init_db(conn)

    jsonl_files = glob.glob(str(PROJECTS_DIR / "**" / "*.jsonl"), recursive=True)
    jsonl_files.sort()

    new_files = 0
    updated_files = 0
    skipped_files = 0
    total_turns = 0
    total_sessions = set()

    for filepath in jsonl_files:
        try:
            mtime = os.path.getmtime(filepath)
        except OSError:
            continue

        row = conn.execute(
            "SELECT mtime, lines FROM processed_files WHERE path = ?",
            (filepath,)
        ).fetchone()

        if row and abs(row["mtime"] - mtime) < 0.01:
            skipped_files += 1
            continue

        is_new = row is None
        if verbose:
            status = "NEW" if is_new else "UPD"
            rel = os.path.relpath(filepath, PROJECTS_DIR)
            print(f"  [{status}] {rel}")

        session_metas, turns = parse_jsonl_file(filepath)

        if not is_new:
            # Incremental: only process new lines
            old_lines = row["lines"] if row else 0
            current_lines = count_lines(filepath)
            if current_lines <= old_lines:
                conn.execute("UPDATE processed_files SET mtime = ? WHERE path = ?",
                             (mtime, filepath))
                conn.commit()
                skipped_files += 1
                continue

            # Re-parse only new lines for turns
            is_sub, parent_id = detect_subagent(filepath)
            new_turns = []
            try:
                with open(filepath, encoding="utf-8", errors="replace") as f:
                    for i, line in enumerate(f):
                        if i < old_lines:
                            continue
                        line = line.strip()
                        if not line:
                            continue
                        try:
                            record = json.loads(line)
                        except json.JSONDecodeError:
                            continue
                        if record.get("type") != "assistant":
                            continue
                        session_id = record.get("sessionId")
                        if not session_id:
                            continue
                        msg = record.get("message", {})
                        usage = msg.get("usage", {})
                        inp = usage.get("input_tokens", 0) or 0
                        out = usage.get("output_tokens", 0) or 0
                        cr = usage.get("cache_read_input_tokens", 0) or 0
                        cc = usage.get("cache_creation_input_tokens", 0) or 0
                        if inp + out + cr + cc == 0:
                            continue
                        tool_name = None
                        for item in msg.get("content", []):
                            if isinstance(item, dict) and item.get("type") == "tool_use":
                                tool_name = item.get("name")
                                break
                        new_turns.append({
                            "session_id": session_id,
                            "timestamp": record.get("timestamp", ""),
                            "model": msg.get("model", ""),
                            "input_tokens": inp,
                            "output_tokens": out,
                            "cache_read": cr,
                            "cache_write": cc,
                            "tool_name": tool_name,
                            "cwd": record.get("cwd", ""),
                        })
            except Exception as e:
                print(f"  Warning: {e}")

            turns = new_turns
            sessions = aggregate_sessions(session_metas, turns)
            updated_files += 1
        else:
            sessions = aggregate_sessions(session_metas, turns)
            new_files += 1

        if sessions:
            upsert_sessions(conn, sessions)
        if turns:
            insert_turns(conn, turns)

        for s in sessions:
            total_sessions.add(s["session_id"])
        total_turns += len(turns)

        line_count = count_lines(filepath)
        conn.execute("""
            INSERT OR REPLACE INTO processed_files (path, mtime, lines)
            VALUES (?, ?, ?)
        """, (filepath, mtime, line_count))
        conn.commit()

    # Import legacy JSONL history if it exists and hasn't been imported
    legacy_imported = conn.execute(
        "SELECT path FROM processed_files WHERE path = '__legacy_jsonl__'"
    ).fetchone()

    if not legacy_imported and HISTORY_FILE.exists():
        if verbose:
            print(f"\n  Importing legacy history from {HISTORY_FILE}...")
        import_count = import_legacy_history(conn)
        conn.execute("""
            INSERT OR REPLACE INTO processed_files (path, mtime, lines)
            VALUES ('__legacy_jsonl__', ?, ?)
        """, (time.time(), import_count))
        conn.commit()
        if verbose:
            print(f"  Imported {import_count} legacy sessions")

    if verbose:
        sess_count = conn.execute("SELECT COUNT(*) FROM sessions").fetchone()[0]
        turn_count = conn.execute("SELECT COUNT(*) FROM turns").fetchone()[0]
        sub_count = conn.execute("SELECT COUNT(*) FROM sessions WHERE is_subagent = 1").fetchone()[0]
        print(f"\nScan complete:")
        print(f"  New files:     {new_files}")
        print(f"  Updated:       {updated_files}")
        print(f"  Skipped:       {skipped_files}")
        print(f"  Turns added:   {total_turns}")
        print(f"  DB totals:     {sess_count} sessions ({sub_count} subagents), {turn_count} turns")

    conn.close()


def import_legacy_history(conn):
    """Import claudetop-history.jsonl sessions into the sessions table."""
    count = 0
    try:
        with open(HISTORY_FILE, encoding="utf-8") as f:
            for line in f:
                line = line.strip()
                if not line:
                    continue
                try:
                    rec = json.loads(line)
                except json.JSONDecodeError:
                    continue

                sid = rec.get("session_id", "")
                if not sid:
                    continue

                # Skip if session already exists from JSONL scan
                existing = conn.execute(
                    "SELECT session_id FROM sessions WHERE session_id = ?", (sid,)
                ).fetchone()
                if existing:
                    continue

                ts = rec.get("timestamp", "")
                cost = rec.get("cost_usd", 0)
                inp = rec.get("input_tokens", 0)
                out = rec.get("output_tokens", 0)

                conn.execute("""
                    INSERT OR IGNORE INTO sessions
                        (session_id, project_name, project_dir, first_timestamp, last_timestamp,
                         git_branch, total_input, total_output, total_cache_read, total_cache_write,
                         model, turn_count, is_subagent, parent_session_id)
                    VALUES (?, ?, ?, ?, ?, ?, ?, ?, 0, 0, ?, 0, 0, NULL)
                """, (
                    sid,
                    rec.get("project", "unknown"),
                    rec.get("project_dir", ""),
                    ts, ts,
                    rec.get("branch", ""),
                    inp, out,
                    rec.get("model", ""),
                ))
                count += 1
        conn.commit()
    except Exception as e:
        print(f"  Warning importing legacy: {e}")
    return count


# ── CLI: Stats ───────────────────────────────────────────────────────────────

def cmd_today():
    if not DB_PATH.exists():
        print("No database found. Run: claudetop-engine scan")
        return
    conn = get_db()
    today = date.today().isoformat()

    rows = conn.execute("""
        SELECT
            COALESCE(model, 'unknown') as model,
            SUM(input_tokens)  as inp,
            SUM(output_tokens) as out,
            SUM(cache_read)    as cr,
            SUM(cache_write)   as cw,
            COUNT(*)           as turns
        FROM turns
        WHERE substr(timestamp, 1, 10) = ?
        GROUP BY model
        ORDER BY inp + out DESC
    """, (today,)).fetchall()

    sessions = conn.execute("""
        SELECT COUNT(DISTINCT session_id) as cnt
        FROM turns WHERE substr(timestamp, 1, 10) = ?
    """, (today,)).fetchone()

    # Subagent stats for today
    sub_stats = conn.execute("""
        SELECT COUNT(DISTINCT t.session_id) as sub_sessions,
               SUM(t.input_tokens) as sub_inp,
               SUM(t.output_tokens) as sub_out
        FROM turns t
        JOIN sessions s ON t.session_id = s.session_id
        WHERE substr(t.timestamp, 1, 10) = ? AND s.is_subagent = 1
    """, (today,)).fetchone()

    # Top tools by cost today
    tools = conn.execute("""
        SELECT tool_name,
               SUM(input_tokens) as inp,
               SUM(output_tokens) as out,
               SUM(cache_read) as cr,
               SUM(cache_write) as cw,
               COUNT(*) as calls
        FROM turns
        WHERE substr(timestamp, 1, 10) = ? AND tool_name IS NOT NULL
        GROUP BY tool_name
        ORDER BY inp + out DESC
        LIMIT 8
    """, (today,)).fetchall()

    hr = "-" * 60
    print(f"\n{hr}")
    print(f"  claudetop — Today ({today})")
    print(hr)

    if not rows:
        print("  No usage recorded today.\n")
        conn.close()
        return

    total_cost = 0
    for r in rows:
        cost = calc_cost(r["model"], r["inp"] or 0, r["out"] or 0, r["cr"] or 0, r["cw"] or 0)
        total_cost += cost
        print(f"  {r['model']:<30}  turns={r['turns']:<4}  "
              f"in={fmt_tokens(r['inp'] or 0):<8}  out={fmt_tokens(r['out'] or 0):<8}  "
              f"cost={fmt_cost(cost)}")

    print(hr)
    print(f"  {'TOTAL':<30}  sessions={sessions['cnt']}  cost={fmt_cost(total_cost)}")

    if sub_stats and sub_stats["sub_sessions"]:
        sub_cost_est = calc_cost("sonnet", sub_stats["sub_inp"] or 0, sub_stats["sub_out"] or 0, 0, 0)
        print(f"\n  Subagents: {sub_stats['sub_sessions']} sessions, ~{fmt_cost(sub_cost_est)} est.")

    if tools:
        print(f"\n  Top tools by token volume:")
        for t in tools:
            vol = (t["inp"] or 0) + (t["out"] or 0)
            print(f"    {t['tool_name']:<25}  {t['calls']:>4} calls  {fmt_tokens(vol)}")

    print(f"{hr}\n")
    conn.close()


def cmd_stats():
    if not DB_PATH.exists():
        print("No database found. Run: claudetop-engine scan")
        return
    conn = get_db()

    totals = conn.execute("""
        SELECT
            SUM(total_input)      as inp,
            SUM(total_output)     as out,
            SUM(total_cache_read) as cr,
            SUM(total_cache_write)as cw,
            SUM(turn_count)       as turns,
            COUNT(*)              as sessions,
            MIN(first_timestamp)  as first_ts,
            MAX(last_timestamp)   as last_ts
        FROM sessions WHERE is_subagent = 0
    """).fetchone()

    sub_totals = conn.execute("""
        SELECT COUNT(*) as sessions,
               SUM(total_input) as inp,
               SUM(total_output) as out,
               SUM(turn_count) as turns
        FROM sessions WHERE is_subagent = 1
    """).fetchone()

    by_model = conn.execute("""
        SELECT COALESCE(model, 'unknown') as model,
               SUM(total_input) as inp, SUM(total_output) as out,
               SUM(total_cache_read) as cr, SUM(total_cache_write) as cw,
               SUM(turn_count) as turns, COUNT(*) as sessions
        FROM sessions
        GROUP BY model ORDER BY inp + out DESC
    """).fetchall()

    top_projects = conn.execute("""
        SELECT project_name,
               SUM(total_input) as inp, SUM(total_output) as out,
               SUM(total_cache_read) as cr, SUM(total_cache_write) as cw,
               SUM(turn_count) as turns, COUNT(*) as sessions
        FROM sessions WHERE is_subagent = 0
        GROUP BY project_name ORDER BY inp + out DESC LIMIT 10
    """).fetchall()

    # Top tools across all time
    top_tools = conn.execute("""
        SELECT tool_name, COUNT(*) as calls,
               SUM(input_tokens + output_tokens) as tokens
        FROM turns WHERE tool_name IS NOT NULL
        GROUP BY tool_name ORDER BY tokens DESC LIMIT 10
    """).fetchall()

    total_cost = sum(
        calc_cost(r["model"], r["inp"] or 0, r["out"] or 0, r["cr"] or 0, r["cw"] or 0)
        for r in by_model
    )

    hr = "=" * 60
    print(f"\n{hr}")
    print("  claudetop — All-Time Statistics")
    print(hr)

    first = (totals["first_ts"] or "")[:10]
    last = (totals["last_ts"] or "")[:10]
    print(f"  Period:          {first} to {last}")
    print(f"  Sessions:        {totals['sessions'] or 0:,} main + {sub_totals['sessions'] or 0:,} subagents")
    print(f"  Turns:           {fmt_tokens(totals['turns'] or 0)}")
    print(f"  Input tokens:    {fmt_tokens(totals['inp'] or 0)}")
    print(f"  Output tokens:   {fmt_tokens(totals['out'] or 0)}")
    print(f"  Cache read:      {fmt_tokens(totals['cr'] or 0)}")
    print(f"  Cache write:     {fmt_tokens(totals['cw'] or 0)}")
    print(f"  Est. total cost: {fmt_cost(total_cost)}")
    print("-" * 60)

    print("  By Model:")
    for r in by_model:
        cost = calc_cost(r["model"], r["inp"] or 0, r["out"] or 0, r["cr"] or 0, r["cw"] or 0)
        print(f"    {r['model']:<28}  sessions={r['sessions']:<4}  "
              f"turns={fmt_tokens(r['turns'] or 0):<6}  cost={fmt_cost(cost)}")

    print("-" * 60)
    print("  Top Projects:")
    for r in top_projects:
        cost = calc_cost("sonnet", r["inp"] or 0, r["out"] or 0, r["cr"] or 0, r["cw"] or 0)
        print(f"    {(r['project_name'] or 'unknown'):<28}  sessions={r['sessions']:<3}  "
              f"turns={fmt_tokens(r['turns'] or 0):<6}  ~{fmt_cost(cost)}")

    if top_tools:
        print("-" * 60)
        print("  Top Tools (by token volume):")
        for t in top_tools:
            print(f"    {t['tool_name']:<28}  {t['calls']:>5} calls  {fmt_tokens(t['tokens'])}")

    print(f"{hr}\n")
