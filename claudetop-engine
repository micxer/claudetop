<script>
const D=/*DATA*/null;
const P=D.pricing;
const MC={opus:'#fb7185',sonnet:'#38bdf8',haiku:'#34d399',other:'#a78bfa'};
let range='30d',selModels=new Set(D.models),sortKey='last',sortDir=-1,charts={};
Chart.defaults.color='#a1a1aa';Chart.defaults.borderColor='#3f3f46';
Chart.defaults.font.family="'JetBrains Mono',monospace";

function init(){
  document.getElementById('meta').textContent='Updated '+D.generated;
  const mp=document.getElementById('model-pills');
  D.models.forEach(m=>{
    const b=document.createElement('button');b.className='pill on';b.textContent=shortModel(m);b.dataset.model=m;
    b.onclick=()=>{if(selModels.has(m)){selModels.delete(m);b.classList.remove('on')}else{selModels.add(m);b.classList.add('on')}render()};
    mp.appendChild(b);
  });
  document.querySelector('.pill[data-r="30d"]').classList.add('on');
  render();
}

function setRange(r){range=r;document.querySelectorAll('.pill[data-r]').forEach(b=>b.classList.toggle('on',b.dataset.r===r));render()}
function toggleAll(on){
  selModels=on?new Set(D.models):new Set();
  document.querySelectorAll('#model-pills .pill').forEach(b=>b.classList.toggle('on',on));
  render();
}

function mfam(m){if(!m)return'other';m=m.toLowerCase();if(m.includes('opus'))return'opus';if(m.includes('sonnet'))return'sonnet';if(m.includes('haiku'))return'haiku';return'other'}
function shortModel(m){if(!m)return'?';if(m.includes('opus'))return'Opus';if(m.includes('sonnet'))return'Sonnet';if(m.includes('haiku'))return'Haiku';return m.split('-').slice(0,2).join('-')}
function mcost(m,inp,out,cr,cw){const f=mfam(m);const p=P[f]||P.sonnet;return inp*p.input/1e6+out*p.output/1e6+(cr||0)*p.cache_read/1e6+(cw||0)*p.cache_write/1e6}
function fmtC(v){return v>=1?'$'+v.toFixed(2):'$'+v.toFixed(3)}
function fmtT(n){if(n>=1e6)return(n/1e6).toFixed(1)+'M';if(n>=1e3)return(n/1e3).toFixed(1)+'K';return''+n}
function fmtD(m){if(m>=60)return Math.floor(m/60)+'h '+Math.round(m%60)+'m';return Math.round(m)+'m'}

function cutoff(){
  if(range==='all')return'1970-01-01';
  const d=new Date();d.setDate(d.getDate()-parseInt(range));return d.toISOString().slice(0,10);
}

function filtered(){const c=cutoff();return D.sessions.filter(s=>s.last_date>=c&&selModels.has(s.model))}

function render(){
  const ss=filtered();
  const main=ss.filter(s=>!s.is_sub),subs=ss.filter(s=>s.is_sub);
  const total=ss.reduce((a,s)=>a+s.cost,0);
  const subTotal=subs.reduce((a,s)=>a+s.cost,0);
  const days=new Set(ss.map(s=>s.last_date)).size;
  const daily=days?total/days:0;
  const avg=main.length?total/main.length:0;

  document.getElementById('s-cost').textContent=fmtC(total);
  document.getElementById('s-cost-s').textContent=fmtT(ss.reduce((a,s)=>a+s.input,0))+' input tokens';
  document.getElementById('s-sess').textContent=main.length;
  document.getElementById('s-sess-s').textContent=days+' day'+(days!==1?'s':'')+', '+subs.length+' subagents';
  document.getElementById('s-daily').textContent=fmtC(daily);
  document.getElementById('s-daily-s').textContent='~$'+(daily*30).toFixed(0)+'/mo projected';
  document.getElementById('s-avg').textContent=fmtC(avg);
  document.getElementById('s-avg-s').textContent='per session';
  document.getElementById('s-sub').textContent=fmtC(subTotal);
  document.getElementById('s-sub-s').textContent=subs.length+' subagent sessions';

  // Animate meter bars (proportional to max reasonable values)
  const bp=v=>Math.min(100,Math.max(5,v))+'%';
  document.getElementById('bar-cost').style.width=bp(total/200*100);
  document.getElementById('bar-sess').style.width=bp(main.length/50*100);
  document.getElementById('bar-daily').style.width=bp(daily/100*100);
  document.getElementById('bar-avg').style.width=bp(avg/30*100);
  document.getElementById('bar-sub').style.width=bp(subTotal/100*100);

  drawHeatmap(ss);drawDaily(ss);drawModel(ss);drawProject(ss);drawTools();drawSubagents();drawTable(ss);
}

// ── Heatmap (GitHub-style contribution calendar) ──
function drawHeatmap(ss){
  const hm=document.getElementById('heatmap');hm.innerHTML='';
  const tip=document.getElementById('hm-tip');
  // Build day→cost map
  const dayMap={};
  ss.forEach(s=>{dayMap[s.last_date]=(dayMap[s.last_date]||0)+s.cost});
  const vals=Object.values(dayMap);
  const maxCost=Math.max(...vals,1);
  // Generate 52 weeks back
  const today=new Date();
  const start=new Date(today);start.setDate(start.getDate()-363);
  start.setDate(start.getDate()-start.getDay()); // align to Sunday
  let d=new Date(start);
  while(d<=today){
    const week=document.createElement('div');week.className='hm-week';
    for(let i=0;i<7&&d<=today;i++){
      const ds=d.toISOString().slice(0,10);
      const cost=dayMap[ds]||0;
      const level=cost===0?0:cost<maxCost*.15?1:cost<maxCost*.35?2:cost<maxCost*.65?3:4;
      const cell=document.createElement('div');cell.className='hm-day';cell.dataset.level=level;
      cell.addEventListener('mouseenter',e=>{
        tip.textContent=ds+': '+fmtC(cost);tip.style.display='block';
        tip.style.left=e.pageX+10+'px';tip.style.top=e.pageY-30+'px';
      });
      cell.addEventListener('mouseleave',()=>{tip.style.display='none'});
      week.appendChild(cell);
      d.setDate(d.getDate()+1);
    }
    hm.appendChild(week);
  }
}

