# ── Dashboard ────────────────────────────────────────────────────────────────

def get_dashboard_data():
    if not DB_PATH.exists():
        return {"error": "No database. Run: claudetop-engine scan"}
    conn = get_db()

    # All models for filter
    models = [r[0] for r in conn.execute("""
        SELECT COALESCE(model, 'unknown') FROM turns
        GROUP BY model ORDER BY SUM(input_tokens + output_tokens) DESC
    """).fetchall()]

    # Daily per-model data
    daily = [{
        "day": r[0], "model": r[1],
        "input": r[2] or 0, "output": r[3] or 0,
        "cache_read": r[4] or 0, "cache_write": r[5] or 0,
        "turns": r[6] or 0,
    } for r in conn.execute("""
        SELECT substr(timestamp, 1, 10), COALESCE(model, 'unknown'),
               SUM(input_tokens), SUM(output_tokens),
               SUM(cache_read), SUM(cache_write), COUNT(*)
        FROM turns GROUP BY 1, 2 ORDER BY 1, 2
    """).fetchall()]

    # All sessions
    sessions = []
    for r in conn.execute("""
        SELECT session_id, project_name, first_timestamp, last_timestamp,
               total_input, total_output, total_cache_read, total_cache_write,
               model, turn_count, is_subagent, parent_session_id, git_branch
        FROM sessions ORDER BY last_timestamp DESC
    """).fetchall():
        try:
            t1 = datetime.fromisoformat(r["first_timestamp"].replace("Z", "+00:00"))
            t2 = datetime.fromisoformat(r["last_timestamp"].replace("Z", "+00:00"))
            dur_min = round((t2 - t1).total_seconds() / 60, 1)
        except Exception:
            dur_min = 0

        cost = calc_cost(
            r["model"],
            r["total_input"] or 0, r["total_output"] or 0,
            r["total_cache_read"] or 0, r["total_cache_write"] or 0
        )
        sessions.append({
            "id": r["session_id"][:8],
            "project": r["project_name"] or "unknown",
            "last": (r["last_timestamp"] or "")[:16].replace("T", " "),
            "last_date": (r["last_timestamp"] or "")[:10],
            "dur_min": dur_min,
            "model": r["model"] or "unknown",
            "turns": r["turn_count"] or 0,
            "input": r["total_input"] or 0,
            "output": r["total_output"] or 0,
            "cache_read": r["total_cache_read"] or 0,
            "cache_write": r["total_cache_write"] or 0,
            "cost": round(cost, 4),
            "is_sub": r["is_subagent"],
            "parent": r["parent_session_id"][:8] if r["parent_session_id"] else None,
            "branch": r["git_branch"] or "",
        })

    # Subagent summary
    sub_stats = conn.execute("""
        SELECT
            COALESCE(s.parent_session_id, 'orphan') as parent,
            COUNT(*) as count,
            SUM(s.total_input) as inp,
            SUM(s.total_output) as out,
            SUM(s.total_cache_read) as cr,
            SUM(s.total_cache_write) as cw
        FROM sessions s WHERE s.is_subagent = 1
        GROUP BY parent ORDER BY inp + out DESC LIMIT 20
    """).fetchall()

    subagent_data = [{
        "parent": r["parent"][:8] if r["parent"] else "orphan",
        "count": r["count"],
        "input": r["inp"] or 0,
        "output": r["out"] or 0,
    } for r in sub_stats]

    # Top tools
    tools = [{
        "name": r[0], "calls": r[1], "tokens": r[2],
    } for r in conn.execute("""
        SELECT tool_name, COUNT(*), SUM(input_tokens + output_tokens)
        FROM turns WHERE tool_name IS NOT NULL
        GROUP BY tool_name ORDER BY 3 DESC LIMIT 15
    """).fetchall()]

    conn.close()

    return {
        "models": models,
        "daily": daily,
        "sessions": sessions,
        "subagents": subagent_data,
        "tools": tools,
        "pricing": {k: v for k, v in PRICING.items()},
        "generated": datetime.now().strftime("%Y-%m-%d %H:%M:%S"),
    }


