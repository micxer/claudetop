#!/bin/bash
# claudetop-dashboard — Live analytics dashboard for Claude Code sessions
# https://github.com/liorwn/claudetop
#
# Now powered by claudetop-engine: scans ALL session JSONL files (not just
# hook-recorded ones), provides per-turn granularity, subagent cost
# attribution, and an interactive live dashboard with auto-refresh.
#
# Usage:
#   claudetop-dashboard            # Scan + open dashboard at localhost:8080
#   claudetop-dashboard --port N   # Use a different port
#   claudetop-dashboard --no-open  # Start server without opening browser

set -euo pipefail

# Find the engine script (same directory as this script, or in PATH)
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ENGINE="${SCRIPT_DIR}/claudetop-engine"

if [ ! -f "$ENGINE" ]; then
  ENGINE="$(command -v claudetop-engine 2>/dev/null || true)"
fi

if [ -z "$ENGINE" ] || [ ! -f "$ENGINE" ]; then
  echo "Error: claudetop-engine not found." >&2
  echo "Expected at: ${SCRIPT_DIR}/claudetop-engine" >&2
  echo "Run install.sh to set up, or ensure claudetop-engine is in PATH." >&2
  exit 1
fi

# Parse args
PORT=8080
for arg in "$@"; do
  case "$arg" in
    --port)
      shift
      PORT="${1:-8080}"
      ;;
    --port=*)
      PORT="${arg#--port=}"
      ;;
  esac
done

exec python3 "$ENGINE" dashboard "$PORT"
