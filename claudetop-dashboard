#!/bin/bash
# claudetop-dashboard — Generate an HTML dashboard from session history
# https://github.com/liorwn/claudetop
#
# Usage:
#   claudetop-dashboard            # Generate and open in browser
#   claudetop-dashboard --no-open  # Generate only, print path

set -euo pipefail

HISTORY_FILE="${HOME}/.claude/claudetop-history.jsonl"
OUTPUT_FILE="/tmp/claudetop-dashboard.html"
NO_OPEN=0

for arg in "$@"; do
  if [ "$arg" = "--no-open" ]; then
    NO_OPEN=1
  fi
done

# --- Dependency check ---
if ! command -v jq &>/dev/null; then
  echo "Error: jq is required. Install with: brew install jq" >&2
  exit 1
fi

# --- History file check ---
if [ ! -f "$HISTORY_FILE" ]; then
  echo "Error: History file not found at $HISTORY_FILE" >&2
  echo "Make sure the session-end hook is installed. See the claudetop README." >&2
  exit 1
fi

# --- Convert JSONL to JSON array ---
SESSIONS_JSON=$(jq -s '.' "$HISTORY_FILE" 2>/dev/null) || {
  echo "Error: Failed to parse history file." >&2
  exit 1
}

# --- Generate HTML ---
cat > "$OUTPUT_FILE" <<'HTMLEOF'
